# Copy to .env (gitignored) and fill in real values. Never commit .env.

# Debug signing — synced into export_presets.cfg before make apk-debug.
ANDROID_DEBUG_KEYSTORE_PATH=
ANDROID_DEBUG_KEYSTORE_USER=androiddebugkey
ANDROID_DEBUG_KEYSTORE_PASS=

# Release signing — synced into export_presets.cfg before make apk-release.
# Never commit the .jks file itself. Back it up in two separate secure locations before first use.
KEYSTORE_PATH=
KEYSTORE_PASS=
KEYSTORE_ALIAS=
KEYSTORE_ALIAS_PASS=
