# Copy to .env (gitignored) and fill in real values. Never commit .env.

# Debug signing - low-stakes, regenerate anytime with docs/build.md's keytool command.
ANDROID_DEBUG_KEYSTORE_PATH=

# Release signing - the permanent Play Store identity. See docs/build.md before generating.
# Never commit the .jks file itself. Back it up in two separate secure locations before first use.
KEYSTORE_PATH=
KEYSTORE_PASS=
KEYSTORE_ALIAS=
KEYSTORE_ALIAS_PASS=
