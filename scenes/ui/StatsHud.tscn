script = ExtResource("1")

; --- ROUND capsule ------------------------------------------------------------
[node name="RoundPanel" type="PanelContainer" parent="."]
unique_name_in_owner = true
size_flags_horizontal = 3

[node name="Inner" type="MarginContainer" parent="RoundPanel"]
theme_override_constants/margin_left = 0
theme_override_constants/margin_right = 4

[node name="HBox" type="HBoxContainer" parent="RoundPanel/Inner"]
theme_override_constants/separation = 8
alignment = 1

[node name="AccentBar" type="ColorRect" parent="RoundPanel/Inner/HBox"]
custom_minimum_size = Vector2(4, 40)
mouse_filter = 2
color = Color(0.72, 0.77, 0.82, 1)

[node name="RoundIcon" type="TextureRect" parent="RoundPanel/Inner/HBox"]
